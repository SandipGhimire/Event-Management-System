model Attendees {
  id           Int        @id @default(autoincrement())
  email        String     @unique
  name         String
  phoneNumber  String?    @unique
  isVeg        Int?
  profilePic   String?
  paymentSlip  String?
  clubName     String?
  membershipID Int?       @unique

  attendeeEvents AttendeeEvent[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([id])
  @@index([email])
  @@index([phoneNumber])
  @@map("attendees")
}

model Event {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  description String?

  attendeeEvents AttendeeEvent[]
}

model AttendeeEvent {
  id         Int       @id @default(autoincrement())
  attendee   Attendees @relation(fields: [attendeeId], references: [id])
  attendeeId Int
  event      Event     @relation(fields: [eventId], references: [id])
  eventId    Int

  completed  Boolean   @default(false)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([attendeeId, eventId])
}