model Attendee {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String
  phoneNumber  String  @unique
  profilePic   String?
  paymentSlip  String?
  clubName     String
  position     String?
  membershipID String? @unique

  isVeg  Boolean
  qrCode String  @unique

  logs AttendeeTaskLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendee")
}

model Task {
  id          Int     @id @default(autoincrement())
  name        String
  description String?

  isActive Boolean @default(true)
  order    Int?
  slug     String  @unique

  logs AttendeeTaskLog[]

  createdAt DateTime @default(now())

  @@map("task")
}

model AttendeeTaskLog {
  id Int @id @default(autoincrement())

  attendee   Attendee @relation(fields: [attendeeId], references: [id])
  attendeeId Int

  task   Task @relation(fields: [taskId], references: [id])
  taskId Int

  scannedBy String?
  createdAt DateTime @default(now())

  @@unique([attendeeId, taskId])
  @@map("attendee_task_log")
}
