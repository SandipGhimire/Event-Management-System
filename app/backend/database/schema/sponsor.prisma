model Sponsor {
    id           Int     @id @default(autoincrement())
    name         String  @unique
    logo         String?
    description  String?
    contribution String?

    links SponsorLink[]

    isActive Boolean @default(true)
    order    Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model SponsorLink {
    id        Int     @id @default(autoincrement())
    sponsor   Sponsor @relation(fields: [sponsorId], references: [id])
    sponsorId Int

    label String
    url   String

    createdAt DateTime @default(now())
}
