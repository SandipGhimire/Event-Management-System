model tenant_details {
  id          BigInt   @id @default(autoincrement())
  tenant_host String   @unique @db.VarChar(255)
  db_host     String   @db.VarChar(255)
  db_port     Int      @default(5432)
  db_username String   @db.VarChar(255)
  db_password String   @db.VarChar(255)
  db_name     String   @db.VarChar(255)
  created_at  DateTime @default(now()) @db.Timestamp(6)
  updated_at  DateTime @default(now()) @db.Timestamp(6)
}
