meta {
  name: Refresh Token
  type: http
  seq: 2
}

post {
  url: {{api_url}}/auth/refresh
  body: none
  auth: inherit
}

headers {
  Authorization: Bearer {{REFRESH_TOKEN}}
}

script:post-response {
  if(res.getStatus() == 201) {
    const jsonData = res.getBody();
    bru.setEnvVar("ACCESS_TOKEN", jsonData.accessToken);
    bru.setEnvVar("REFRESH_TOKEN", jsonData.refreshToken);
    bru.setEnvVar("SESSION_ID", jsonData.sessionId);
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
