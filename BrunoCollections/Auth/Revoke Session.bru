meta {
  name: Revoke Session
  type: http
  seq: 7
}

delete {
  url: {{api_url}}/auth/sessions/{{SESSION_ID}}
  body: none
  auth: inherit
}

script:post-response {
  if(res.getStatus() == 200) {
    bru.setEnvVar("ACCESS_TOKEN", "");
    bru.setEnvVar("REFRESH_TOKEN", "");
    bru.setEnvVar("SESSION_ID", "");
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
