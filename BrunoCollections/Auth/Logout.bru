meta {
  name: Logout
  type: http
  seq: 4
}

get {
  url: {{api_url}}/auth/logout
  body: none
  auth: inherit
}

script:post-response {
  if(res.getStatus() == 200) {
    bru.setEnvVar("ACCESS_TOKEN", "");
    bru.setEnvVar("REFRESH_TOKEN", "");
    bru.setEnvVar("SESSION_ID", "");
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
